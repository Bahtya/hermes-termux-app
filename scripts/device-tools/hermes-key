#!/bin/bash
# hermes-key — Press a global key
# Usage: hermes-key back|home|recents|notifications|quick_settings|power_dialog|lock_screen|take_screenshot
set -euo pipefail

if [[ $# -lt 1 ]]; then
    echo "Usage: hermes-key <key>" >&2
    echo "Keys: back, home, recents, notifications, quick_settings, power_dialog, lock_screen, take_screenshot" >&2
    exit 1
fi

curl -s -X POST http://localhost:18720/key \
    -H "Content-Type: application/json" \
    -d "{\"key\":\"$1\"}"
echo
