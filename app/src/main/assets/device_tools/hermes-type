#!/bin/bash
# hermes-type — Type text into the focused input field
# Usage: hermes-type "要输入的文字"
set -euo pipefail

if [[ $# -lt 1 ]]; then
    echo "Usage: hermes-type <text>" >&2
    exit 1
fi

TEXT="$1"
# Escape JSON special characters
ESCAPED=$(printf '%s' "$TEXT" | sed 's/\\/\\\\/g; s/"/\\"/g; s/\n/\\n/g')

curl -s -X POST http://localhost:18720/type \
    -H "Content-Type: application/json" \
    -d "{\"text\":\"$ESCAPED\"}"
echo
