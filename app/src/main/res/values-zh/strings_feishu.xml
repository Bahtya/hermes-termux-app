    <string name="feishu_domain_feishu_hint">适用于中国大陆用户</string>
    <string name="feishu_domain_lark">Lark — 国际版</string>
    <string name="feishu_domain_lark_hint">适用于中国大陆以外用户</string>

    <!-- Step 2: Scan QR Code -->
    <string name="feishu_scan_step_title">扫描二维码</string>
    <string name="feishu_scan_step_desc">打开手机上的飞书或 Lark，扫描下方二维码即可创建机器人。</string>
    <string name="feishu_scan_connecting">正在连接飞书…</string>
    <string name="feishu_scan_hint">打开手机上的飞书 / Lark，扫描下方二维码</string>
    <string name="feishu_scan_waiting">等待扫码中…</string>
    <string name="feishu_scan_countdown">剩余 %1$d 分 %2$d 秒</string>
