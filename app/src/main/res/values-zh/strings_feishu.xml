<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Activity title -->
    <string name="feishu_setup_title">飞书 / Lark 设置</string>

    <!-- Step 1: Welcome -->
    <string name="feishu_welcome_title">欢迎使用飞书集成</string>
    <string name="feishu_welcome_description">将 Hermes 连接到飞书或 Lark 机器人，即可在聊天中接收终端通知、运行命令，以及获取手机上的实时提醒。\n\n本向导将引导您完成以下步骤：\n• 创建飞书/Lark 应用\n• 输入机器人凭证\n• 配置连接\n\n您需要拥有飞书或 Lark 开发者权限的账号。</string>

    <!-- Step 2: Choose Domain -->
    <string name="feishu_domain_title">选择平台</string>
    <string name="feishu_domain_description">请选择您使用的版本（国内飞书或国际版 Lark）。</string>
    <string name="feishu_domain_feishu">飞书 — 中国大陆</string>
    <string name="feishu_domain_feishu_desc">适用于中国大陆用户。使用 open.feishu.cn 接口。</string>
    <string name="feishu_domain_lark">Lark — 国际版</string>
    <string name="feishu_domain_lark_desc">适用于中国大陆以外用户。使用 open.larksuite.com 接口。</string>

    <!-- Step 3: Create App -->
    <string name="feishu_create_app_title">创建应用</string>
    <string name="feishu_create_app_instructions">请按以下步骤创建机器人应用：\n\n1. 打开开发者控制台\n2. 点击\"创建自建应用\"\n3. 填写应用名称和描述\n4. 在\"权限管理\"中启用：\n   • im:message（发送消息）\n   • im:message.receive_v1（接收消息）\n5. 在\"事件订阅\"中添加消息接收事件\n6. 在凭证页面记录您的 App ID 和 App Secret</string>
    <string name="feishu_open_console">打开开发者控制台</string>

    <!-- Step 4: Enter Credentials -->
    <string name="feishu_credentials_title">输入应用凭证</string>
    <string name="feishu_credentials_description">请输入飞书/Lark 应用凭证页面中的 App ID 和 App Secret。</string>
    <string name="feishu_app_id_hint">App ID (cli_xxxxxxxxxxxx)</string>
    <string name="feishu_app_secret_hint">App Secret</string>
    <string name="feishu_app_id_label">App ID</string>
    <string name="feishu_app_secret_label">App Secret</string>
    <string name="feishu_credentials_error_empty">请输入 App ID 和 App Secret</string>
    <string name="feishu_credentials_error_invalid_id">App ID 应以 \"cli_\" 开头</string>

    <!-- Step 5: Configure Bot -->
    <string name="feishu_configure_title">配置连接</string>
    <string name="feishu_connection_mode">连接模式</string>
    <string name="feishu_mode_websocket">WebSocket（推荐）</string>
    <string name="feishu_mode_websocket_desc">保持持久连接。最适合实时消息。可在 NAT/防火墙后使用。</string>
    <string name="feishu_mode_webhook">Webhook</string>
    <string name="feishu_mode_webhook_desc">需要公网可访问的 URL。Hermes 将向您的端点 POST 事件。</string>
    <string name="feishu_qr_code_title">机器人配对</string>
    <string name="feishu_qr_code_description">使用飞书/Lark 扫描此二维码配对机器人，或在组织中按名称搜索机器人。</string>
    <string name="feishu_qr_generating">正在生成二维码…</string>

    <!-- Step 6: Complete -->
    <string name="feishu_complete_title">设置完成！</string>
    <string name="feishu_complete_summary">您的飞书/Lark 机器人已配置完成。\n\n配置已保存到 Hermes 设置。\n\n您现在可以：\n• 将终端输出发送到飞书聊天\n• 接收长时间运行命令的通知\n• 从飞书消息执行命令</string>
    <string name="feishu_complete_save">保存并完成</string>

    <!-- Navigation -->
    <string name="feishu_button_next">下一步</string>
    <string name="feishu_button_back">上一步</string>
    <string name="feishu_button_cancel">取消</string>
    <string name="feishu_button_finish">完成</string>

    <!-- Confirmation -->
    <string name="feishu_confirm_cancel_title">取消设置？</string>
    <string name="feishu_confirm_cancel_message">确定要取消吗？不会保存任何设置。</string>
    <string name="feishu_confirm_cancel_yes">是，取消</string>
    <string name="feishu_confirm_cancel_no">继续设置</string>

    <!-- Toasts -->
    <string name="feishu_config_saved">飞书配置保存成功</string>
    <string name="feishu_config_error">保存配置失败</string>

    <!-- Content description -->
    <string name="feishu_step_indicator">第 %1$d 步，共 %2$d 步</string>
</resources>
