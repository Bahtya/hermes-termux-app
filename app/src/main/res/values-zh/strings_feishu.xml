<resources>
    <!-- Activity title -->
    <string name="feishu_setup_title">飞书 / Lark 设置</string>

    <!-- Step 0: Welcome -->
    <string name="feishu_welcome_title">连接飞书 / Lark</string>
    <string name="feishu_scan_welcome_desc">Hermes 可以连接飞书或 Lark，让您直接在聊天中与 AI 助手对话。\n\n只需用手机扫一下二维码即可，无需任何技术知识。机器人会自动创建。</string>
    <string name="feishu_scan_welcome_steps">您需要：\n\n• 手机上的飞书或 Lark 账号\n• 大约 1 分钟\n\n只需扫描二维码即可完成！</string>

    <!-- Step 1: Choose Domain -->
    <string name="feishu_step2_title">选择平台</string>
    <string name="feishu_step2_desc">请选择您使用的版本（国内飞书或国际版 Lark）。</string>
    <string name="feishu_domain_label">选择平台：</string>
