    <string name="llm_model_info_title">关于此模型</string>
    <string name="model_desc_gpt_4o">旗舰模型。适合复杂推理、分析和创意任务。响应快速，全能型选手。</string>
    <string name="model_desc_gpt_4o_mini">快速且经济实惠。适合简单任务、快速回答和高频使用。</string>
    <string name="model_desc_o1">高级推理模型。逐步思考，擅长数学、科学和复杂问题解决。较慢但更深入。</string>
    <string name="model_desc_o1_mini">更快的推理模型。推理能力和速度的良好平衡。</string>
    <string name="model_desc_o3_mini">最新推理模型。更高的效率和更强的复杂任务处理能力。</string>
    <string name="model_desc_gpt_4_turbo">上一代旗舰模型。依然强大，但推荐使用更新模型。</string>
    <string name="model_desc_claude_sonnet">速度与智能的最佳平衡。推荐用于大多数任务——写作、分析、编码和对话。</string>
    <string name="model_desc_claude_opus">最强大的模型。擅长复杂分析、精细写作和挑战性问题。成本较高，响应较慢。</string>
    <string name="model_desc_claude_haiku">最快的 Claude 模型。适合快速任务、分类和对速度要求最高的场景。最经济实惠。</string>
    <string name="model_desc_gemini_pro">最强大的 Gemini 模型。擅长推理、多语言任务和长上下文。适合复杂工作。</string>
    <string name="model_desc_gemini_flash">快速高效。适合日常任务，质量优秀。性价比高。</string>
    <string name="model_desc_gemini_flash2">上一代 flash 模型。响应快速，成本更低。</string>
    <string name="model_desc_deepseek_chat">通用模型。擅长编码和数学。性价比极高。</string>
    <string name="model_desc_deepseek_reasoner">展示思考过程的推理模型。适合复杂逻辑和数学问题。</string>
    <string name="model_desc_openrouter_default">通过一个 API 访问多个提供商。可选择任意模型，费用因提供商而异。</string>
    <string name="model_desc_grok_3">最新的 Grok 模型，具备实时知识。适合时事和通用任务。</string>
    <string name="model_desc_grok_3_mini">更小、更快的 Grok 模型。适合快速任务，成本更低。</string>
    <string name="model_desc_qwen_max">最强大的通义千问模型。中文支持卓越，通用推理能力强。</string>
    <string name="model_desc_qwen_plus">性能与成本的平衡。适合大多数任务，中文支持强大。</string>
    <string name="model_desc_qwen_turbo">最快的通义千问模型。适合简单任务和高频使用。最经济实惠。</string>
    <string name="model_desc_mistral_large">最强大的 Mistral 模型。擅长复杂指令遵循和多语言任务。</string>
    <string name="model_desc_mistral_medium">平衡型模型。性能适中，成本合理。</string>
    <string name="model_desc_codestral">专注于代码生成和理解。最适合编程任务。</string>
    <string name="model_desc_llama_70b">Meta 开源模型。强大的通用能力，运行在 NVIDIA 基础设施上。</string>
    <string name="model_desc_deepseek_r1_nvidia">展示思考过程的推理模型。擅长数学和逻辑问题。</string>
    <string name="model_desc_gemma_27b">Google 开源模型。体积小但能力不俗。</string>
    <string name="model_desc_nemotron_70b">NVIDIA 微调模型。针对帮助性和指令遵循进行了优化。</string>
    <string name="model_desc_llama3_local">Meta 热门开源模型。本地运行，完全私密。通用性良好。</string>
    <string name="model_desc_qwen25_local">强大的多语言模型。中英文支持出色。本地运行。</string>
    <string name="model_desc_deepseek_r1_local">展示思考过程的强大推理模型。适合复杂问题。本地运行。</string>
    <string name="model_desc_gemma2_local">Google 高效开源模型。速度与质量的良好平衡。本地运行。</string>
