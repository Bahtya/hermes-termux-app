    <string name="telegram_setup_title">Telegram 机器人设置</string>
    <string name="telegram_welcome_title">连接到 Telegram</string>
    <string name="telegram_welcome_desc">Hermes 可以连接到 Telegram，让您直接在 Telegram 消息中与 AI 助手对话。</string>
    <string name="telegram_token_title">机器人令牌</string>
    <string name="telegram_token_hint">粘贴从 @BotFather 获取的机器人令牌</string>
    <string name="telegram_allowed_users_title">允许的用户（可选）</string>
    <string name="telegram_allowed_users_hint">逗号分隔的用户 ID（留空允许所有用户）</string>
    <string name="telegram_get_token_steps">如何获取机器人令牌：\n\n1. 打开 Telegram 并搜索 @BotFather\n2. 发送 /newbot 创建新机器人\n3. 选择机器人的名称和用户名\n4. 复制 BotFather 提供的机器人令牌</string>
    <string name="telegram_test_title">测试连接</string>
    <string name="telegram_test_desc">验证您的机器人令牌是否有效。</string>
    <string name="telegram_test_success">机器人令牌有效！Telegram 机器人已就绪。</string>
    <string name="telegram_test_fail">机器人令牌无效 — 请检查后重试。</string>
    <string name="telegram_complete_title">Telegram 设置完成！</string>
    <string name="telegram_complete_next_steps">后续步骤：\n\n• 从设置中启动 Hermes 网关\n• 在 Telegram 中向您的机器人发送消息\n• 您可以随时从 Hermes 设置中修改这些设置</string>

    <string name="discord_setup_title">Discord 机器人设置</string>
    <string name="discord_welcome_title">连接到 Discord</string>
    <string name="discord_welcome_desc">Hermes 可以连接到 Discord，让您在 Discord 服务器和私信中与 AI 助手对话。</string>
    <string name="discord_token_title">机器人令牌</string>
    <string name="discord_token_hint">粘贴从 Discord 开发者门户获取的机器人令牌</string>
    <string name="discord_allowed_users_title">允许的用户（可选）</string>
    <string name="discord_allowed_users_hint">逗号分隔的 Discord 用户 ID（留空允许所有用户）</string>
    <string name="discord_get_token_steps">如何获取机器人令牌：\n\n1. 访问 discord.com/developers/applications\n2. 点击\"New Application\"并命名\n3. 进入\"Bot\"部分，点击\"Reset Token\"\n4. 复制机器人令牌\n5. 在 Bot > Privileged Gateway Intents 下启用\"Message Content Intent\"</string>
    <string name="discord_test_title">测试连接</string>
    <string name="discord_test_desc">验证您的机器人令牌是否有效。</string>
    <string name="discord_test_success">机器人令牌有效！Discord 机器人已就绪。</string>
    <string name="discord_test_fail">机器人令牌无效 — 请检查后重试。</string>
    <string name="discord_complete_title">Discord 设置完成！</string>
    <string name="discord_complete_next_steps">后续步骤：\n\n• 邀请您的机器人到 Discord 服务器\n• 从设置中启动 Hermes 网关\n• 在 Discord 中向您的机器人发送消息\n• 您可以随时从 Hermes 设置中修改这些设置</string>

    <!-- Feishu Setup - strings also in strings_feishu.xml are translated there -->

    <!-- Feishu welcome step strings -->
    <string name="feishu_welcome_desc">Hermes 可以连接飞书或 Lark，让您直接在消息中与 AI 助手对话。本向导将引导您完成几个简单步骤的设置。</string>
    <string name="feishu_welcome_steps">您将进行以下操作：\n\n1. 选择平台（飞书或 Lark）\n2. 在开发者控制台创建机器人\n3. 输入应用凭证\n4. 测试连接\n\n⏱ 大约需要 3-5 分钟</string>

    <!-- Feishu step 2: Domain -->
    <string name="feishu_step2_title">选择平台</string>
    <string name="feishu_step2_desc">选择您使用的平台。飞书适用于中国用户，Lark 适用于国际用户。</string>
    <string name="feishu_domain_feishu_hint">适用于中国大陆用户</string>
    <string name="feishu_domain_lark_hint">适用于国际用户</string>

    <!-- Feishu step 3: Create App -->
    <string name="feishu_step3_title">创建机器人</string>
    <string name="feishu_step3_desc">按照以下步骤在飞书开发者控制台创建机器人应用。</string>
    <string name="feishu_create_app_tip">💡 提示：创建应用后，进入\"机器人\"部分并启用机器人能力。然后在凭证页面找到您的 App ID 和 App Secret。</string>

    <!-- Feishu step 4: Credentials -->
    <string name="feishu_step4_title">输入凭证</string>
    <string name="feishu_step4_desc">用飞书扫描下方二维码打开凭证页面，或手动输入。</string>
    <string name="feishu_qr_scan_hint">用飞书扫描此二维码打开开发者控制台：</string>
    <string name="feishu_manual_entry_label">或手动输入凭证：</string>
    <string name="feishu_paste">粘贴</string>
    <string name="feishu_toggle_visibility">显示</string>
    <string name="feishu_paste_detected">检测到 App ID！点击填入：%1$s</string>
    <string name="feishu_app_id_format_hint">App ID 通常以 \"cli_\" 开头</string>
    <string name="feishu_credentials_short">凭证看起来太短 — 请仔细检查</string>
    <string name="feishu_credentials_ok">凭证看起来有效</string>
    <string name="feishu_credentials_required">App ID 和 App Secret 为必填项</string>

    <!-- Feishu step 5: Test -->
    <string name="feishu_step5_title">测试连接</string>
    <string name="feishu_step5_desc">在保存之前验证您的配置。这将测试凭证是否正确。</string>
    <string name="feishu_test_config_summary">平台：%1$s\nApp ID：%2$s\n连接：%3$s</string>
    <string name="feishu_test_ready">点击\"测试连接\"验证您的凭证</string>
    <string name="feishu_run_test">测试连接</string>
    <string name="feishu_test_running">正在测试连接…</string>
    <string name="feishu_test_success">连接测试通过！机器人已就绪。</string>
    <string name="feishu_test_warning">无法验证连接，但凭证看起来有效。您可以继续稍后再测试。</string>
    <string name="feishu_skip_test">跳过测试</string>

    <!-- Feishu step 6: Complete -->
    <string name="feishu_save_success">设置完成！</string>
    <string name="feishu_complete_next_steps">后续步骤：\n\n• 从设置中启动 Hermes 网关以开始接收消息\n• 在飞书中向您的机器人发送消息开始对话\n• 您可以随时从 Hermes 设置中修改这些设置</string>

