<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Activity title -->
    <string name="feishu_setup_title">Feishu / Lark Setup</string>

    <!-- Step 0: Welcome -->
    <string name="feishu_welcome_title">Connect to Feishu / Lark</string>
    <string name="feishu_scan_welcome_desc">Hermes can connect to Feishu or Lark so you can chat with your AI assistant directly in messages.\n\nSimply scan a QR code with your phone — no technical knowledge needed. A bot will be created automatically.</string>
    <string name="feishu_scan_welcome_steps">What you\'ll need:\n\n• A Feishu or Lark account on your phone\n• About 1 minute\n\nYou\'ll just scan a QR code and you\'re done!</string>

    <!-- Step 1: Choose Domain -->
    <string name="feishu_step2_title">Choose Platform</string>
    <string name="feishu_step2_desc">Select which platform you use. Feishu is for China, Lark is for international users.</string>
    <string name="feishu_domain_label">Select your platform:</string>
    <string name="feishu_domain_feishu">Feishu (飞书)</string>
    <string name="feishu_domain_feishu_hint">For users in mainland China</string>
    <string name="feishu_domain_lark">Lark (International)</string>
    <string name="feishu_domain_lark_hint">For international users</string>

    <!-- Step 2: Scan QR Code -->
    <string name="feishu_scan_step_title">Scan QR Code</string>
    <string name="feishu_scan_step_desc">Open Feishu or Lark on your phone and scan the QR code below to create your bot.</string>
    <string name="feishu_scan_connecting">Connecting to Feishu…</string>
    <string name="feishu_scan_hint">Open Feishu / Lark on your phone and scan the QR code below</string>
    <string name="feishu_scan_waiting">Waiting for scan…</string>
    <string name="feishu_scan_countdown">%1$dm %2$ds remaining</string>
    <string name="feishu_scan_success">Scan successful! Creating bot…</string>
    <string name="feishu_scan_probing">Verifying bot…</string>
    <string name="feishu_scan_complete">Bot created successfully!</string>
    <string name="feishu_scan_complete_with_name">Bot \"%1$s\" created successfully!</string>
    <string name="feishu_scan_not_ready">Please wait for the scan to complete</string>
    <string name="feishu_scan_timeout">QR code expired. Please scan again.</string>
    <string name="feishu_scan_denied">Authorization denied. Please try again.</string>
    <string name="feishu_scan_error_init">Failed to connect to Feishu. Please check your network.</string>
    <string name="feishu_scan_error_begin">Failed to get QR code. Please try again.</string>
    <string name="feishu_scan_error_network">Network error. Please check your connection.</string>
    <string name="feishu_scan_error_probe">Bot created, but verification failed (safe to continue).</string>
    <string name="feishu_rescan">Scan Again</string>

    <!-- Step 3: Complete -->
    <string name="feishu_save_success">Setup Complete!</string>
    <string name="feishu_scan_complete_summary">Bot: %1$s\nPlatform: %2$s\nApp ID: %3$s</string>
    <string name="feishu_complete_next_steps">Next steps:\n\n• Start the Hermes Gateway from Settings to begin receiving messages\n• Send a message to your bot on Feishu to start chatting\n• You can change these settings anytime from Hermes Settings</string>

    <!-- Navigation -->
    <string name="feishu_button_next">Next</string>
    <string name="feishu_button_back">Back</string>
    <string name="feishu_button_cancel">Cancel</string>
    <string name="feishu_button_finish">Finish</string>

    <!-- Confirmation -->
    <string name="feishu_confirm_cancel_title">Cancel Setup?</string>
    <string name="feishu_confirm_cancel_message">Are you sure you want to cancel? No settings will be saved.</string>
    <string name="feishu_confirm_cancel_yes">Yes, Cancel</string>
    <string name="feishu_confirm_cancel_no">Continue Setup</string>

    <!-- Toasts -->
    <string name="feishu_config_saved">Feishu configuration saved successfully</string>
    <string name="feishu_config_error">Failed to save configuration</string>

    <!-- Content description -->
