    <string name="feishu_welcome_desc">Hermes can connect to Feishu (飞书) or Lark so you can chat with your AI assistant directly in messages. This wizard will guide you through the setup in a few simple steps.</string>
    <string name="feishu_welcome_steps">What you\'ll do:\n\n1. Choose your platform (Feishu or Lark)\n2. Create a bot in the Developer Console\n3. Enter your App credentials\n4. Test the connection\n\n⏱ Takes about 3–5 minutes</string>

    <!-- Step 2: Domain -->
    <string name="feishu_step2_title">Choose Platform</string>
    <string name="feishu_step2_desc">Select which platform you use. Feishu is for China, Lark is for international users.</string>
    <string name="feishu_domain_label">Select your platform:</string>
    <string name="feishu_domain_feishu">Feishu (飞书)</string>
    <string name="feishu_domain_feishu_hint">For users in mainland China</string>
    <string name="feishu_domain_lark">Lark (International)</string>
    <string name="feishu_domain_lark_hint">For international users</string>

    <!-- Step 3: Create App -->
    <string name="feishu_step3_title">Create Your Bot</string>
    <string name="feishu_step3_desc">Follow these steps in the Feishu Developer Console to create your bot app.</string>
    <string name="feishu_create_app_tip">💡 Tip: After creating the app, go to \"Bot\" section and enable the bot capability. Then find your App ID and App Secret on the app\'s credentials page.</string>
    <string name="feishu_open_console">Open Developer Console</string>

    <string-array name="feishu_create_app_steps">
        <item>Open the Developer Console by tapping the button below</item>
        <item>Tap \"Create App\" and choose \"Bot\" as the app type</item>
        <item>Enter a name for your bot (e.g. \"My Hermes Bot\")</item>
        <item>Go to \"Bot\" section and enable bot capability</item>
        <item>Copy the App ID and App Secret from the credentials page</item>
    </string-array>

    <!-- Step 4: Credentials -->
    <string name="feishu_step4_title">Enter Credentials</string>
    <string name="feishu_step4_desc">Scan the QR code below with Feishu to open the credentials page, or enter them manually.</string>
    <string name="feishu_qr_scan_hint">Scan this QR code with Feishu to open the Developer Console:</string>
    <string name="feishu_manual_entry_label">Or enter credentials manually:</string>
    <string name="feishu_paste">Paste</string>
    <string name="feishu_toggle_visibility">Show</string>
    <string name="feishu_paste_detected">App ID detected! Tap to fill: %1$s</string>
    <string name="feishu_app_id_label">App ID</string>
    <string name="feishu_app_secret_label">App Secret</string>
    <string name="feishu_app_id_format_hint">App ID usually starts with \"cli_\"</string>
    <string name="feishu_credentials_short">Credentials look too short — please double-check</string>
    <string name="feishu_credentials_ok">Credentials look valid</string>
    <string name="feishu_credentials_required">App ID and App Secret are required</string>
    <string name="feishu_connection_mode">Connection Mode</string>
    <string name="feishu_mode_websocket">WebSocket (Recommended)</string>
    <string name="feishu_mode_webhook">Webhook</string>

    <!-- Step 5: Test -->
    <string name="feishu_step5_title">Test Connection</string>
    <string name="feishu_step5_desc">Let\'s verify your configuration before saving. This tests that your credentials are correct.</string>
    <string name="feishu_test_config_summary">Platform: %1$s\nApp ID: %2$s\nConnection: %3$s</string>
    <string name="feishu_test_ready">Tap \"Test Connection\" to verify your credentials</string>
    <string name="feishu_run_test">Test Connection</string>
    <string name="feishu_test_running">Testing connection…</string>
    <string name="feishu_test_success">Connection test passed! Your bot is ready.</string>
    <string name="feishu_test_warning">Could not verify connection, but credentials look valid. You can continue and test later.</string>

    <!-- Step 6: Complete -->
    <string name="feishu_save_success">Setup Complete!</string>
    <string name="feishu_complete_summary">Platform: %1$s\nApp ID: %2$s…\nConnection: %3$s</string>
    <string name="feishu_complete_next_steps">Next steps:\n\n• Start the Hermes Gateway from Settings to begin receiving messages\n• Send a message to your bot on Feishu to start chatting\n• You can change these settings anytime from Hermes Settings</string>

    <!-- Hermes Web -->
    <string name="hermes_web_title">Hermes Web</string>
    <string name="hermes_web_not_found_title">Web UI not found</string>
    <string name="hermes_web_not_found_message">Hermes web server is not running. Start the gateway to enable the web UI.</string>
    <string name="hermes_web_start_gateway">Start Gateway</string>
    <string name="hermes_not_installed_title">Hermes not installed</string>
    <string name="hermes_not_installed_message">Hermes Agent is not installed yet at:\n%1$s\n\nPlease wait for the auto-install to complete.</string>

    <!-- Hermes Setup Wizard -->
    <string name="hermes_setup_wizard_title">Hermes Setup</string>
    <string name="hermes_setup_step_welcome">Welcome</string>
    <string name="hermes_setup_step_llm">AI Configuration</string>
    <string name="hermes_setup_step_feishu">Messaging</string>
    <string name="hermes_setup_step_done">All Done!</string>
    <string name="hermes_setup_welcome_title">Welcome to Hermes!</string>
    <string name="hermes_setup_welcome_text">Hermes connects AI assistants to your messaging apps. This wizard will help you get started in just a few steps.\n\nYou\'ll need:\n• An API key from an AI provider (OpenAI, Anthropic, etc.)\n• Optionally, a messaging account (Feishu, Telegram, Discord)</string>
    <string name="hermes_setup_llm_title">Configure your AI</string>
    <string name="hermes_setup_llm_text">Select your AI provider and enter your API key. This is required for Hermes to work.</string>
    <string name="hermes_setup_api_key_hint">Paste your API key here</string>
    <string name="hermes_setup_feishu_title">Connect Feishu/Lark</string>
    <string name="hermes_setup_feishu_text">You can connect Hermes to Feishu/Lark to chat with your AI assistant directly in messages. This step is optional — you can set it up later from Hermes Settings.</string>
    <string name="hermes_setup_open_feishu_wizard">Setup Feishu/Lark</string>
    <string name="hermes_setup_feishu_skip">You can skip this step and configure Feishu later from Hermes Settings.</string>
    <string name="hermes_setup_done_title">You\'re all set!</string>
    <string name="hermes_setup_done_text">Hermes is ready to go. You can start the gateway from the Hermes Settings or use the Web UI tab.\n\nTo change your settings at any time, tap the Hermes icon in the sidebar.</string>

