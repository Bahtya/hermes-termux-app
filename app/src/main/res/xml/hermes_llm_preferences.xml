<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">

    <ListPreference
        android:key="llm_preset"
        android:title="@string/llm_preset_title"
        android:summary="@string/llm_preset_summary"
        android:entries="@array/llm_preset_names"
        android:entryValues="@array/llm_preset_values"
        android:defaultValue="balanced" />

    <PreferenceCategory
        android:key="llm_category_auth"
        android:title="@string/llm_category_auth">

        <EditTextPreference
            android:key="llm_api_key"
            android:title="@string/llm_api_key_title"
            android:summary="@string/llm_api_key_summary"
            android:inputType="textPassword" />

        <Preference
            android:key="llm_api_key_hint"
            android:selectable="false"
            android:summary="@string/llm_api_key_hint_openai" />

        <Preference
            android:key="llm_paste_api_key"
            android:title="@string/llm_paste_key_title"
            android:summary="@string/llm_paste_key_summary" />

        <Preference
            android:key="llm_get_api_key"
            android:title="@string/llm_get_api_key_title"
            android:summary="@string/llm_get_api_key_summary" />

        <Preference
            android:key="llm_docs"
            android:title="@string/llm_docs_title"
            android:summary="@string/llm_docs_summary" />

    </PreferenceCategory>

    <PreferenceCategory
        android:key="llm_category_provider"
        android:title="@string/llm_category_provider">

        <ListPreference
            android:key="llm_provider"
            android:title="@string/llm_provider_title"
            android:summary="@string/llm_provider_summary"
            android:entries="@array/llm_provider_names"
            android:entryValues="@array/llm_provider_values"
            android:defaultValue="openai" />

        <Preference
            android:key="llm_provider_info"
            android:title="@string/llm_provider_info_title"
            android:selectable="false" />

        <Preference
            android:key="llm_cost_estimate"
            android:title="@string/llm_cost_title"
            android:selectable="false" />

    </PreferenceCategory>

    <PreferenceCategory
        android:key="llm_category_endpoint"
        android:title="@string/llm_category_endpoint">

        <EditTextPreference
            android:key="llm_base_url"
            android:title="@string/llm_base_url_title"
            android:summary="@string/llm_base_url_summary"
            android:inputType="textUri" />

        <Preference
            android:key="llm_base_url_hint"
            android:selectable="false"
            android:summary="@string/llm_base_url_hint_default" />

    </PreferenceCategory>

    <PreferenceCategory
        android:key="llm_category_model"
        android:title="@string/llm_category_model">

        <ListPreference
            android:key="llm_model"
            android:title="@string/llm_model_title"
            android:summary="@string/llm_model_summary"
            android:entries="@array/llm_models_openai"
            android:entryValues="@array/llm_models_openai"
            android:defaultValue="gpt-4o" />

        <EditTextPreference
            android:key="llm_custom_model"
            android:title="@string/llm_custom_model_title"
            android:summary="@string/llm_custom_model_summary"
            android:inputType="textVisiblePassword" />

    </PreferenceCategory>

    <PreferenceCategory android:title="@string/llm_params_category_title">
        <EditTextPreference
            android:key="llm_temperature"
            android:title="@string/llm_temperature_title"
            android:summary="@string/llm_temperature_summary"
            android:inputType="numberDecimal"
            android:defaultValue="0.7" />

        <EditTextPreference
            android:key="llm_max_tokens"
            android:title="@string/llm_max_tokens_title"
            android:summary="@string/llm_max_tokens_summary"
            android:inputType="number"
            android:defaultValue="4096" />
    </PreferenceCategory>

    <PreferenceCategory
        android:key="llm_category_persona"
        android:title="@string/llm_category_persona">
        <Preference
            android:key="llm_persona_template"
            android:title="@string/llm_persona_template_title"
            android:summary="@string/llm_persona_template_summary" />

        <EditTextPreference
            android:key="llm_system_prompt"
            android:title="@string/llm_system_prompt_title"
            android:summary="@string/llm_system_prompt_summary"
            android:inputType="textMultiLine" />

        <Preference
            android:key="llm_system_prompt_templates"
            android:title="@string/llm_templates_title"
            android:summary="@string/llm_templates_summary" />
    </PreferenceCategory>

    <PreferenceCategory android:title="@string/llm_category_test">
        <Preference
            android:key="llm_test_connection"
            android:title="@string/llm_test_connection_title"
            android:summary="@string/llm_test_connection_summary"
            android:selectable="true" />
    </PreferenceCategory>

    <PreferenceCategory android:title="@string/llm_category_share">
        <Preference
            android:key="llm_export_qr"
            android:title="@string/llm_export_qr_title"
            android:summary="@string/llm_export_qr_summary" />
        <Preference
            android:key="llm_import_qr"
            android:title="@string/llm_import_qr_title"
            android:summary="@string/llm_import_qr_summary" />
    </PreferenceCategory>

</PreferenceScreen>
