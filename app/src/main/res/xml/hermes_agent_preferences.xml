<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">

    <PreferenceCategory android:title="@string/agent_category_context">
        <SwitchPreferenceCompat
            android:key="agent_compression_enabled"
            android:title="@string/agent_compression_title"
            android:summary="@string/agent_compression_summary"
            android:defaultValue="true" />

        <EditTextPreference
            android:key="agent_compression_threshold"
            android:title="@string/agent_compression_threshold_title"
            android:summary="@string/agent_compression_threshold_summary"
            android:inputType="numberDecimal"
            android:defaultValue="0.5" />

        <EditTextPreference
            android:key="agent_context_length"
            android:title="@string/agent_context_length_title"
            android:summary="@string/agent_context_length_summary"
            android:inputType="number"
            android:defaultValue="128000" />
    </PreferenceCategory>

    <PreferenceCategory android:title="@string/agent_category_behavior">
        <EditTextPreference
            android:key="agent_max_turns"
            android:title="@string/agent_max_turns_title"
            android:summary="@string/agent_max_turns_summary"
            android:inputType="number"
            android:defaultValue="30" />

        <EditTextPreference
            android:key="agent_gateway_timeout"
            android:title="@string/agent_gateway_timeout_title"
            android:summary="@string/agent_gateway_timeout_summary"
            android:inputType="number"
            android:defaultValue="300" />

        <SwitchPreferenceCompat
            android:key="agent_verbose"
            android:title="@string/agent_verbose_title"
            android:summary="@string/agent_verbose_summary"
            android:defaultValue="false" />
    </PreferenceCategory>

    <PreferenceCategory android:title="@string/agent_category_memory">
        <SwitchPreferenceCompat
            android:key="agent_memory_enabled"
            android:title="@string/agent_memory_title"
            android:summary="@string/agent_memory_summary"
            android:defaultValue="true" />

        <SwitchPreferenceCompat
            android:key="agent_user_profile_enabled"
            android:title="@string/agent_user_profile_title"
            android:summary="@string/agent_user_profile_summary"
            android:defaultValue="true" />

        <EditTextPreference
            android:key="agent_memory_char_limit"
            android:title="@string/agent_memory_limit_title"
            android:summary="@string/agent_memory_limit_summary"
            android:inputType="number"
            android:defaultValue="2000" />
    </PreferenceCategory>

    <PreferenceCategory android:title="@string/agent_category_session">
        <ListPreference
            android:key="agent_session_reset_mode"
            android:title="@string/agent_session_reset_title"
            android:summary="@string/agent_session_reset_summary"
            android:entries="@array/agent_session_reset_names"
            android:entryValues="@array/agent_session_reset_values"
            android:defaultValue="none" />

        <EditTextPreference
            android:key="agent_session_idle_minutes"
            android:title="@string/agent_session_idle_title"
            android:summary="@string/agent_session_idle_summary"
            android:inputType="number"
            android:defaultValue="60" />

        <EditTextPreference
            android:key="agent_session_reset_hour"
            android:title="@string/agent_session_reset_hour_title"
            android:summary="@string/agent_session_reset_hour_summary"
            android:inputType="number"
            android:defaultValue="3" />
    </PreferenceCategory>

    <PreferenceCategory android:title="Tool Management">
        <SwitchPreferenceCompat
            android:key="agent_tool_terminal"
            android:title="Terminal Commands"
            android:summary="Allow agent to execute terminal commands"
            android:defaultValue="true" />

        <SwitchPreferenceCompat
            android:key="agent_tool_web_search"
            android:title="Web Search"
            android:summary="Allow agent to search the web"
            android:defaultValue="true" />

        <SwitchPreferenceCompat
            android:key="agent_tool_file_ops"
            android:title="File Operations"
            android:summary="Allow agent to read and write files"
            android:defaultValue="true" />

        <SwitchPreferenceCompat
            android:key="agent_tool_browser"
            android:title="Browser"
            android:summary="Allow agent to browse websites"
            android:defaultValue="true" />

        <SwitchPreferenceCompat
            android:key="agent_tool_code_exec"
            android:title="Code Execution"
            android:summary="Allow agent to execute code snippets"
            android:defaultValue="true" />
    </PreferenceCategory>

    <PreferenceCategory android:title="@string/browser_category_title">
        <EditTextPreference
            android:key="browser_inactivity_timeout"
            android:title="@string/browser_inactivity_timeout_title"
            android:summary="@string/browser_inactivity_timeout_summary"
            android:inputType="number"
            android:defaultValue="30" />

        <EditTextPreference
            android:key="browser_user_agent"
            android:title="@string/browser_user_agent_title"
            android:summary="@string/browser_user_agent_summary"
            android:inputType="textVisiblePassword" />

        <SwitchPreferenceCompat
            android:key="browser_headless"
            android:title="@string/browser_headless_title"
            android:summary="@string/browser_headless_summary"
            android:defaultValue="true" />

        <EditTextPreference
            android:key="browser_max_tabs"
            android:title="@string/browser_max_tabs_title"
            android:summary="@string/browser_max_tabs_summary"
            android:inputType="number"
            android:defaultValue="5" />
    </PreferenceCategory>

    <PreferenceCategory android:title="@string/voice_category_title">
        <ListPreference
            android:key="voice_provider"
            android:title="@string/voice_provider_title"
            android:summary="@string/voice_provider_summary"
            android:entries="@array/voice_provider_names"
            android:entryValues="@array/voice_provider_values"
            android:defaultValue="openai" />

        <EditTextPreference
            android:key="voice_language"
            android:title="@string/voice_language_title"
            android:summary="@string/voice_language_summary"
            android:inputType="text"
            android:defaultValue="en" />

        <ListPreference
            android:key="voice_local_model"
            android:title="@string/voice_local_model_title"
            android:summary="@string/voice_local_model_summary"
            android:entries="@array/voice_whisper_model_names"
            android:entryValues="@array/voice_whisper_model_values"
            android:defaultValue="base" />

        <EditTextPreference
            android:key="voice_custom_endpoint"
            android:title="@string/voice_custom_endpoint_title"
            android:summary="@string/voice_custom_endpoint_summary"
            android:inputType="textUri" />
    </PreferenceCategory>

    <PreferenceCategory android:title="@string/rate_limit_category_title">
        <EditTextPreference
            android:key="rate_limit_user_per_min"
            android:title="@string/rate_limit_user_per_min_title"
            android:summary="@string/rate_limit_user_per_min_summary"
            android:inputType="number"
            android:defaultValue="10" />

        <EditTextPreference
            android:key="rate_limit_global_per_min"
            android:title="@string/rate_limit_global_per_min_title"
            android:summary="@string/rate_limit_global_per_min_summary"
            android:inputType="number"
            android:defaultValue="30" />

        <EditTextPreference
            android:key="rate_limit_cooldown"
            android:title="@string/rate_limit_cooldown_title"
            android:summary="@string/rate_limit_cooldown_summary"
            android:inputType="number"
            android:defaultValue="5" />

        <EditTextPreference
            android:key="rate_limit_concurrent"
            android:title="@string/rate_limit_concurrent_title"
            android:summary="@string/rate_limit_concurrent_summary"
            android:inputType="number"
            android:defaultValue="3" />

        <ListPreference
            android:key="rate_limit_queue_mode"
            android:title="@string/rate_limit_queue_mode_title"
            android:summary="@string/rate_limit_queue_mode_summary"
            android:entries="@array/rate_limit_queue_mode_names"
            android:entryValues="@array/rate_limit_queue_mode_values"
            android:defaultValue="queue" />
    </PreferenceCategory>

    <PreferenceCategory android:title="@string/logging_category_title">
        <ListPreference
            android:key="logging_level"
            android:title="@string/logging_level_title"
            android:summary="@string/logging_level_summary"
            android:entries="@array/logging_level_names"
            android:entryValues="@array/logging_level_values"
            android:defaultValue="INFO" />

        <SwitchPreferenceCompat
            android:key="logging_to_file"
            android:title="@string/logging_to_file_title"
            android:summary="@string/logging_to_file_summary"
            android:defaultValue="true" />

        <EditTextPreference
            android:key="logging_max_file_size"
            android:title="@string/logging_max_file_size_title"
            android:summary="@string/logging_max_file_size_summary"
            android:inputType="number"
            android:defaultValue="10" />

        <EditTextPreference
            android:key="logging_max_files"
            android:title="@string/logging_max_files_title"
            android:summary="@string/logging_max_files_summary"
            android:inputType="number"
            android:defaultValue="5" />
    </PreferenceCategory>

</PreferenceScreen>
