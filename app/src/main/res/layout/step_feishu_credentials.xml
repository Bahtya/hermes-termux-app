<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/feishu_credentials_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/feishu_credentials_description"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="24dp" />

        <!-- App ID input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/input_layout_app_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/feishu_app_id_hint"
            app:startIconDrawable="@android:drawable/ic_menu_info_details"
            app:helperTextEnabled="true"
            app:helperText="@string/feishu_app_id_label"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_app_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textVisiblePassword"
                android:singleLine="true"
                android:textSize="15sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- App Secret input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/input_layout_app_secret"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/feishu_app_secret_hint"
            app:startIconDrawable="@android:drawable/ic_lock_lock"
            app:endIconMode="password_toggle"
            app:helperTextEnabled="true"
            app:helperText="@string/feishu_app_secret_label">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_app_secret"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:singleLine="true"
                android:textSize="15sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Error text (hidden by default) -->
        <TextView
            android:id="@+id/credentials_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorError"
            android:textSize="13sp"
            android:visibility="gone"
            android:paddingTop="8dp" />

    </LinearLayout>
</ScrollView>
