<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/feishu_domain_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/feishu_domain_description"
            android:textSize="15sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="24dp" />

        <RadioGroup
            android:id="@+id/domain_radio_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Feishu option -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_feishu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:checkable="true"
                android:clickable="true"
                app:strokeColor="?attr/colorPrimary"
                app:strokeWidth="2dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RadioButton
                        android:id="@+id/radio_feishu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/feishu_domain_feishu"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="?android:attr/textColorPrimary"
                        android:layout_marginBottom="4dp"
                        android:checked="true" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/feishu_domain_feishu_desc"
                        android:textSize="13sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:paddingStart="38dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Lark option -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_lark"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RadioButton
                        android:id="@+id/radio_lark"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/feishu_domain_lark"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="?android:attr/textColorPrimary"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/feishu_domain_lark_desc"
                        android:textSize="13sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:paddingStart="38dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </RadioGroup>

    </LinearLayout>
</ScrollView>
