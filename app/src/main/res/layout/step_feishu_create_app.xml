<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/feishu_create_app_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginBottom="16dp" />

        <!-- Instructions card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="?android:attr/colorBackground"
            app:strokeColor="?android:attr/listDivider"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/feishu_create_app_instructions"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorPrimary"
                android:lineSpacingMultiplier="1.4"
                android:padding="16dp" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Open console button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_open_console"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/feishu_open_console"
            android:textSize="15sp"
            android:layout_gravity="center_horizontal"
            app:icon="@android:drawable/ic_menu_share"
            app:iconGravity="textStart"
            app:backgroundTint="?attr/colorPrimary" />

    </LinearLayout>
</ScrollView>
